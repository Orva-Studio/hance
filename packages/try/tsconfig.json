{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["vite/client", "@webgpu/types"],
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      "@hance/ui/app/*": ["../ui/app/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
