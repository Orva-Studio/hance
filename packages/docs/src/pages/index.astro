---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { TRY_URL } from '../../site.config';

const REPO = 'https://github.com/Orva-Studio/hance';
const INSTALL = '$ npx @orva-studio/hance your-video.mp4';

const effects = ['Color', 'Halation', 'Bloom', 'Grain', 'Vignette', 'Split Tone', 'Aberration', 'Shake'];

// Before/after carousel slides. Every "after" was graded by hance with the named preset.
const compareSlides = [
  { key: 'default', preset: 'cinestill-800t', subject: 'Neon night street' },
  { key: 'surf', preset: 'provia-100f', subject: 'Surfer carving a wave', tuned: true },
  { key: 'runner', preset: 'ultramax-400', subject: 'Sprinter on the blocks', tuned: true },
  { key: 'city', preset: 'kodachrome-64', subject: 'City skyline at golden hour', tuned: true },
];

const steps = [
  {
    n: '01',
    title: 'Preview',
    body: 'Open the browser editor on your own footage, try looks, and dial one in. No install step. npx fetches the latest hance. You just need FFmpeg on your PATH.',
    code: ['$ npx @orva-studio/hance ui your-video.mp4', '→ http://localhost:4800'],
  },
  {
    n: '02',
    title: 'Render',
    body: 'Bake the look into a new file at export quality. One render graph, no intermediate files, no plugins, no LUT pipeline.',
    code: ['$ hance your-video.mp4 --preset portra-400 --export high', '→ your-video_hanced.mp4'],
  },
  {
    n: '03',
    title: 'Import',
    body: 'Drop the graded clip into CapCut, iMovie, ScreenFlow, anywhere. The film look is already baked into the pixels.',
    code: ['→ CapCut · iMovie · ScreenFlow · the web'],
  },
];

const faqs = [
  {
    q: 'Is this a plugin for DaVinci or Premiere?',
    a: 'Not today. Hance is a standalone CLI plus an optional local browser UI. It runs anywhere FFmpeg runs and slots into your existing pipeline rather than living inside an NLE. A native plugin is technically feasible down the line, most likely as an OFX plugin for DaVinci Resolve, but it is not on the near-term roadmap.',
  },
  {
    q: 'Is hance free? How much does it cost?',
    a: 'Hance is free to use and source-available. Every effect, all 40+ film looks, the browser UI, and the AI agent skill cost nothing. A paid Pro tier is coming soon, adding ProRes export, batch processing, and premium looks. Pricing is not yet announced; see the Free vs Pro page for the full breakdown.',
  },
  {
    q: 'Does my footage leave my machine?',
    a: 'No. Everything happens locally on your GPU, so there is no upload, and your files never leave your disk.',
  },
  {
    q: 'Why CLI-first?',
    a: 'Because batch grading, ingest pipelines, and scripted workflows should not require dragging clips into a GUI. A CLI is also the native interface for AI agents; drive hance from Claude Code or Cursor with the /hance skill, no clicking required. The optional UI is for dialing in a look; the CLI is for applying it at scale.',
  },
  {
    q: 'What does the optional UI do?',
    a: 'Live preview while you tune effects on real footage. When you like the result, save it as a .hlook preset and apply it from the command line, by name, forever.',
  },
  {
    q: 'Linux and Windows?',
    a: 'macOS is the primary target during beta. Linux works and is lightly tested, and hance ships native binaries for both (arm64/x64). Windows is not supported.',
  },
  {
    q: 'Does it work with ComfyUI or AI video pipelines?',
    a: 'Today, yes — because hance is a CLI, any pipeline can shell out to it as a post-process step to add a film look to generated frames. A dedicated ComfyUI node is on the roadmap to make that a drag-and-drop step rather than a script.',
  },
  {
    q: 'License?',
    a: 'FSL-1.1-Apache-2.0. Free to use, modify, and redistribute. Cannot be used to build a competing product or service. Converts to Apache 2.0 on April 1, 2028.',
  },
];

// FAQPage structured data, built from the same `faqs` array so the markup
// and the rendered Q&As can never drift apart.
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
};
---
<Base>
  <!-- NAV -->
  <Nav />

  <!-- HERO -->
  <section class="px-6 sm:px-10 lg:px-16 pt-16 sm:pt-24 lg:pt-28 pb-20 sm:pb-28">
    <div class="max-w-[1280px] mx-auto">
      <h1 class="font-sans font-medium tracking-tightest-2 leading-[1.05] text-ink text-balance"
          style="font-size: clamp(1.95rem, 4.2vw, 3.85rem); max-width: 32ch">
        Cinematic film looks for any editor,
        <span class="text-ink-muted">rendered in one command, no plugins, no LUTs.</span>
      </h1>

      <div class="mt-10 sm:mt-12 flex flex-wrap items-center gap-4">
        <button
          id="install-copy"
          type="button"
          class="group cursor-pointer inline-flex max-w-full items-center gap-2 sm:gap-3 rounded-full border border-accent/70 hover:border-accent pl-4 sm:pl-5 pr-2.5 sm:pr-3 py-2 sm:py-2.5 font-mono text-[12px] sm:text-sm text-ink transition-colors duration-300 ease-out-quart"
          data-copy={INSTALL.replace(/^\$\s*/, '')}
          aria-label="Copy run command"
        >
          <span class="text-accent select-none">$</span>
          <span class="select-all truncate">npx @orva-studio/hance your-video.mp4</span>
          <span class="ml-1 sm:ml-2 inline-flex items-center gap-1.5 rounded-full bg-accent/10 text-accent/90 px-2 sm:px-2.5 py-0.5 sm:py-1 text-[10px] sm:text-[11px] tracking-wide uppercase shrink-0" data-label>
            copy
          </span>
        </button>
        <a
          href={TRY_URL}
          class="inline-flex items-center gap-2 rounded-full bg-accent px-5 sm:px-6 py-2 sm:py-2.5 font-mono text-[12px] sm:text-sm uppercase tracking-wide text-surface-1 transition-transform duration-300 ease-out-quart hover:-translate-y-px"
        >
          Try free online
        </a>
      </div>

      <!-- Reel: clips graded with the hance portra-400 look -->
      <figure class="mt-16 sm:mt-20">
        <p class="mb-4 font-mono text-[11px] sm:text-[12px] text-white uppercase tracking-[0.14em]">
          Every clip and still on this page was graded by <a href="https://claude.com/claude-code" class="text-accent hover:underline underline-offset-4">Claude Code</a> with hance. Fully autonomous, zero human touch.
        </p>
        <div id="reel" class="group relative aspect-video rounded-md ring-1 ring-surface-3 overflow-hidden bg-surface-2 cursor-pointer">
          <video
            id="reel-video"
            class="absolute inset-0 w-full h-full object-cover cursor-pointer"
            autoplay
            loop
            muted
            playsinline
            preload="metadata"
            poster="/reel-poster.webp"
            aria-label="A reel of clips graded with hance"
          >
            <source src="/reel.webm" type="video/webm" />
            <source src="/reel.mp4" type="video/mp4" />
          </video>
          <div class="filmstrip-grain absolute inset-0 pointer-events-none"></div>

          <!-- Custom controls -->
          <div class="reel-controls absolute inset-x-0 bottom-0 flex items-center gap-3 sm:gap-4 px-3 sm:px-4 py-3 sm:py-3.5">
            <button id="reel-toggle" type="button" class="shrink-0 grid place-items-center size-9 rounded-full bg-surface/80 ring-1 ring-accent/70 hover:ring-accent text-accent transition cursor-pointer" aria-label="Pause">
              <svg class="reel-icon-pause size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7 5h3.5v14H7zM13.5 5H17v14h-3.5z"/></svg>
              <svg class="reel-icon-play size-4 hidden translate-x-[1px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9 6v12l9-6z"/></svg>
            </button>
            <div id="reel-track" class="relative flex-1 h-1.5 rounded-full bg-ink/25 cursor-pointer">
              <div id="reel-progress" class="absolute inset-y-0 left-0 rounded-full bg-accent" style="width:0%"></div>
              <div id="reel-thumb" class="absolute top-1/2 -translate-y-1/2 -translate-x-1/2 size-3 rounded-full bg-accent shadow ring-2 ring-surface" style="left:0%"></div>
            </div>
            <span id="reel-time" class="shrink-0 font-mono text-[11px] text-ink-muted tabular-nums select-none">0:00</span>
          </div>
        </div>
        <figcaption class="mt-4">
          <p class="font-mono text-[11px] sm:text-[12px] text-ink-dim/80 tracking-[0.04em]">
            Source footage is a mix of real clips from <a href="https://www.pexels.com" class="text-accent hover:underline underline-offset-4">Pexels</a> and AI-generated clips from <a href="https://ai.byteplus.com/lumina/" class="text-accent hover:underline underline-offset-4">Lumina</a>.
          </p>
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- EFFECTS STRIP -->
  <section class="px-6 sm:px-10 lg:px-16 py-14 sm:py-20 border-t border-surface-3/70" aria-labelledby="effects-heading">
    <div class="max-w-[1280px] mx-auto">
      <p id="effects-heading" class="font-mono text-[12px] sm:text-[13px] text-ink-dim uppercase tracking-[0.18em]">
        Eight effects. One render graph. Zero intermediate files.
      </p>
      <ul class="mt-6 sm:mt-8 flex flex-wrap items-baseline gap-x-4 sm:gap-x-6 gap-y-2 font-sans">
        {effects.map((e, i) => (
          <li class="flex items-baseline gap-x-4 sm:gap-x-6">
            <span class="text-ink text-[clamp(1.35rem,3.6vw,2.75rem)] font-medium tracking-tight">{e}</span>
            {i < effects.length - 1 && (
              <span class="text-accent/70 select-none text-[clamp(1rem,2vw,1.5rem)]" aria-hidden="true">·</span>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- BEFORE / AFTER -->
  <section class="px-6 sm:px-10 lg:px-16 py-20 sm:py-28" aria-labelledby="proof-heading">
    <div class="max-w-[1280px] mx-auto">
      <p id="proof-heading" class="font-mono text-[12px] sm:text-[13px] text-ink-dim uppercase tracking-[0.18em]">
        Drag to compare. Untouched on the left, hance on the right.
      </p>

      <div id="ba-carousel" class="mt-6 sm:mt-8 relative" aria-roledescription="carousel" aria-label="Before and after comparisons">
        <!-- Viewport -->
        <div class="overflow-hidden rounded-md ring-1 ring-surface-3">
          <div id="ba-track" class="flex transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]">
            {compareSlides.map((slide, i) => {
              const before = slide.key === 'default' ? '/compare-before.webp' : `/compare-${slide.key}-before.webp`;
              const after = slide.key === 'default' ? '/compare-after.webp' : `/compare-${slide.key}-after.webp`;
              return (
                <div
                  class="ba-slide w-full shrink-0"
                  role="group"
                  aria-roledescription="slide"
                  aria-label={`${i + 1} of ${compareSlides.length}: ${slide.subject}`}
                >
                  <div
                    class="ba relative aspect-video w-full overflow-hidden select-none touch-none"
                    data-preset={slide.preset}
                    data-tuned={slide.tuned ? 'true' : 'false'}
                  >
                    <!-- Before: untouched original -->
                    <img src={before} alt={`${slide.subject}, untouched before grading`} class="absolute inset-0 w-full h-full object-cover" draggable="false" loading={i === 0 ? 'eager' : 'lazy'} />
                    <!-- After: graded with hance -->
                    <div class="ba-after absolute inset-0">
                      <img src={after} alt={`${slide.subject}, graded with the hance ${slide.preset} look`} class="absolute inset-0 w-full h-full object-cover" draggable="false" loading={i === 0 ? 'eager' : 'lazy'} />
                    </div>

                    <!-- Labels -->
                    <span class="absolute top-4 left-4 font-mono text-[11px] text-ink-muted uppercase tracking-wider bg-surface/60 px-2 py-1 rounded">before</span>
                    <span class="absolute top-4 right-4 font-mono text-[11px] text-accent uppercase tracking-wider bg-surface/60 px-2 py-1 rounded">after</span>

                    <!-- Handle -->
                    <div class="ba-handle absolute top-0 bottom-0 w-px bg-accent" aria-hidden="true">
                      <div class="absolute top-1/2 -translate-x-1/2 -translate-y-1/2 size-10 rounded-full bg-surface ring-2 ring-accent flex items-center justify-center">
                        <svg viewBox="0 0 24 24" class="size-4 fill-accent" aria-hidden="true"><path d="M9 6l-6 6 6 6V6zm6 0v12l6-6-6-6z"/></svg>
                      </div>
                    </div>

                    <!-- Native input for keyboard a11y -->
                    <input
                      type="range"
                      min="0" max="100" step="1" value="50"
                      aria-label={`Comparison position for ${slide.subject}`}
                      class="ba-range absolute inset-0 w-full h-full opacity-0 cursor-ew-resize"
                    />
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        <!-- Arrows -->
        <button
          id="ba-prev"
          type="button"
          aria-label="Previous comparison"
          class="absolute left-3 top-[calc(50%-1.5rem)] -translate-y-1/2 size-10 rounded-full bg-surface/70 ring-1 ring-surface-3 text-ink hover:bg-surface hover:ring-accent transition flex items-center justify-center backdrop-blur-sm"
        >
          <svg viewBox="0 0 24 24" class="size-5 fill-current" aria-hidden="true"><path d="M15 6l-6 6 6 6V6z"/></svg>
        </button>
        <button
          id="ba-next"
          type="button"
          aria-label="Next comparison"
          class="absolute right-3 top-[calc(50%-1.5rem)] -translate-y-1/2 size-10 rounded-full bg-surface/70 ring-1 ring-surface-3 text-ink hover:bg-surface hover:ring-accent transition flex items-center justify-center backdrop-blur-sm"
        >
          <svg viewBox="0 0 24 24" class="size-5 fill-current" aria-hidden="true"><path d="M9 6l6 6-6 6V6z"/></svg>
        </button>

        <!-- Caption + dots -->
        <div class="mt-4 flex items-center justify-between gap-4">
          <p class="font-mono text-[12px] text-ink-dim">
            <span class="text-ink-muted">graded with</span>
            <span id="ba-caption" class="text-accent">{compareSlides[0].preset}</span><span id="ba-tuned" class="text-ink-dim">{compareSlides[0].tuned ? ' (tuned)' : ''}</span>
          </p>
          <div id="ba-dots" class="flex items-center gap-2" role="tablist" aria-label="Choose comparison">
            {compareSlides.map((slide, i) => (
              <button
                type="button"
                class="ba-dot size-2.5 rounded-full bg-surface-3 transition hover:bg-ink-dim"
                role="tab"
                aria-label={`Show ${slide.subject}`}
                data-index={i}
              ></button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- QUICKSTART -->
  <section class="px-6 sm:px-10 lg:px-16 py-20 sm:py-28 border-t border-surface-3/70" aria-labelledby="quickstart-heading">
    <div class="max-w-[1280px] mx-auto">
      <h2 id="quickstart-heading" class="font-sans font-medium text-ink tracking-tightest-2 leading-[0.95]" style="font-size: clamp(2.25rem, 5.5vw, 4.25rem)">
        Preview. Render. Ship.
      </h2>
      <ol class="mt-14 sm:mt-20 grid gap-14 sm:gap-20">
        {steps.map((s) => (
          <li class="grid grid-cols-12 gap-x-6 gap-y-5 items-start">
            <div class="col-span-12 sm:col-span-2 font-mono text-[13px] text-accent tracking-[0.18em]">{s.n}</div>
            <div class="col-span-12 sm:col-span-4">
              <h3 class="font-sans text-2xl sm:text-3xl font-medium tracking-tight text-ink">{s.title}</h3>
              <p class="mt-3 max-w-[40ch] text-ink-muted leading-relaxed">{s.body}</p>
            </div>
            <div class="col-span-12 sm:col-span-6">
              <div class="cb">
                {s.code.map((line) => {
                  const glyph = line.startsWith('$') ? '$' : line.startsWith('→') ? '→' : '';
                  const rest = glyph ? line.slice(1).trimStart() : line;
                  const hashIdx = rest.indexOf('#');
                  const cmd = hashIdx >= 0 ? rest.slice(0, hashIdx).trimEnd() : rest;
                  const comment = hashIdx >= 0 ? rest.slice(hashIdx) : '';
                  return (
                    <div class="cb-row">
                      <span class="cb-glyph">{glyph || ' '}</span>
                      <span class="cb-cmd">{cmd}{comment && <span class="cb-comment">{comment}</span>}</span>
                    </div>
                  );
                })}
              </div>
            </div>
          </li>
        ))}
      </ol>

      <!-- Browser editor screenshot -->
      <figure class="mt-14 sm:mt-20">
        <figcaption class="mb-4 font-mono text-[12px] sm:text-[13px] text-ink-dim uppercase tracking-[0.18em]">
          hance ships with a browser UI to fine-tune your grade live. <a href="/docs/browser-ui/" class="text-accent hover:underline underline-offset-4">Tour the UI</a>.
        </figcaption>
        <img
          src="/img/browser-ui.jpg"
          width="1600"
          height="964"
          loading="lazy"
          decoding="async"
          alt="The hance browser editor with a split before/after preview, the looks panel on the left, and effect adjustments on the right."
          class="w-full rounded-md ring-1 ring-surface-3"
        />
        <p class="mt-4 font-mono text-[11px] sm:text-[12px] text-ink-dim/80 tracking-[0.04em]">
          Source photo from <a href="https://www.pexels.com/photo/woman-posing-with-eyes-closed-7658538/" class="text-accent hover:underline underline-offset-4">Pexels</a>.
        </p>
      </figure>

      <!-- Pipeline / automation upsell -->
      <div class="mt-16 sm:mt-24 grid gap-5 sm:gap-6 sm:grid-cols-2">
        <div class="rounded-lg border border-surface-3/70 p-6 sm:p-8">
          <h3 class="font-sans text-xl sm:text-2xl font-medium tracking-tight text-ink">Pipe in your renders</h3>
          <p class="mt-3 max-w-[44ch] text-ink-muted leading-relaxed">
            Already rendering with Remotion, Manim, or raw FFmpeg? Send the output through hance to add film
            grain, halation, and bloom no LUT can fake.
          </p>
          <a href="/docs/recipes/animation-pipelines/" class="mt-5 inline-flex items-center gap-1.5 font-mono text-[13px] text-accent hover:underline underline-offset-4">
            Animation pipeline recipes →
          </a>
        </div>
        <div class="rounded-lg border border-surface-3/70 p-6 sm:p-8">
          <h3 class="font-sans text-xl sm:text-2xl font-medium tracking-tight text-ink">Batch a whole folder</h3>
          <p class="mt-3 max-w-[44ch] text-ink-muted leading-relaxed">
            Apply one consistent look across hundreds of clips, headless, no GUI in the loop. One render graph
            per clip, no intermediate files.
          </p>
          <div class="cb mt-5">
            <div class="cb-row"><span class="cb-glyph">$</span><span class="cb-cmd">hance *.mov --preset portra-400 -o ./graded/</span></div>
          </div>
          <a href="/docs/free-vs-pro/" class="mt-5 inline-flex items-center gap-1.5 font-mono text-[13px] text-accent hover:underline underline-offset-4">
            Batch requires Pro →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- INSTALL -->
  <section id="install" class="px-6 sm:px-10 lg:px-16 py-20 sm:py-28 border-t border-surface-3/70" aria-labelledby="install-heading">
    <div class="max-w-[1280px] mx-auto">
      <h2 id="install-heading" class="font-sans font-medium text-ink tracking-tightest-2 leading-[0.95]" style="font-size: clamp(2.25rem, 5.5vw, 4.25rem)">
        Ways to install.
      </h2>
      <p class="mt-6 max-w-[52ch] text-ink-muted leading-relaxed">
        macOS and Linux. The only requirement is FFmpeg on your PATH.
      </p>
      <div class="mt-14 sm:mt-20 grid gap-5 sm:gap-6 sm:grid-cols-2">
        <div class="rounded-lg border border-surface-3/70 p-6 sm:p-8 flex flex-col">
          <h3 class="font-sans text-xl sm:text-2xl font-medium tracking-tight text-ink">Run with npx</h3>
          <p class="mt-3 text-ink-muted leading-relaxed">No install step — npx fetches and runs the latest hance on demand. The quickest way to try it.</p>
          <div class="cb-block mt-5">
            <div class="cb">
              <div class="cb-row"><span class="cb-glyph">$</span><span class="cb-cmd">npx @orva-studio/hance</span></div>
            </div>
            <button type="button" class="cb-copy" data-copy="npx @orva-studio/hance" aria-label="Copy command"><span data-label>Copy</span></button>
          </div>
          <a href="/docs/getting-started/installation/#run-with-npx-no-install" class="mt-5 inline-flex items-center gap-1.5 font-mono text-[13px] text-accent hover:underline underline-offset-4">Details →</a>
        </div>
        <div class="rounded-lg border border-surface-3/70 p-6 sm:p-8 flex flex-col">
          <h3 class="font-sans text-xl sm:text-2xl font-medium tracking-tight text-ink">From your AI agent</h3>
          <p class="mt-3 text-ink-muted leading-relaxed">Drive hance from Claude Code or Cursor. The skill's setup command checks FFmpeg and gets you ready in one step.</p>
          <div class="cb-block mt-5">
            <div class="cb">
              <div class="cb-row"><span class="cb-glyph">&gt;</span><span class="cb-cmd">/hance setup</span></div>
            </div>
            <button type="button" class="cb-copy" data-copy="/hance setup" aria-label="Copy command"><span data-label>Copy</span></button>
          </div>
          <a href="/docs/agent/overview/" class="mt-5 inline-flex items-center gap-1.5 font-mono text-[13px] text-accent hover:underline underline-offset-4">Set up the skill →</a>
        </div>
        <div class="rounded-lg border border-surface-3/70 p-6 sm:p-8 flex flex-col">
          <h3 class="font-sans text-xl sm:text-2xl font-medium tracking-tight text-ink">Install the CLI</h3>
          <p class="mt-3 text-ink-muted leading-relaxed">For frequent use, install a persistent binary to <span class="font-mono text-[0.9em]">~/.hance/bin</span>. No Bun, Rust, or Node required.</p>
          <div class="cb-block mt-5">
            <div class="cb">
              <div class="cb-row"><span class="cb-glyph">$</span><span class="cb-cmd">curl -fsSL https://hance.video/install.sh | sh</span></div>
            </div>
            <button type="button" class="cb-copy" data-copy="curl -fsSL https://hance.video/install.sh | sh" aria-label="Copy command"><span data-label>Copy</span></button>
          </div>
          <a href="/docs/getting-started/installation/#install-a-persistent-binary" class="mt-5 inline-flex items-center gap-1.5 font-mono text-[13px] text-accent hover:underline underline-offset-4">Details →</a>
        </div>
        <div class="rounded-lg border border-surface-3/70 p-6 sm:p-8 flex flex-col">
          <div class="flex items-center gap-3">
            <h3 class="font-sans text-xl sm:text-2xl font-medium tracking-tight text-ink">Mac app</h3>
            <span class="inline-flex items-center rounded-full border border-accent/70 bg-accent/10 px-2.5 py-0.5 font-mono text-[10px] text-accent uppercase tracking-wide">Beta</span>
          </div>
          <p class="mt-3 text-ink-muted leading-relaxed">A native macOS app for grading without the terminal - the full hance look engine in a desktop window. Apple silicon (Intel coming soon).</p>
          <a href="/mac-install/" class="mt-5 inline-flex items-center gap-2 self-start rounded-full bg-accent px-5 py-2 font-mono text-[12px] uppercase tracking-wide text-surface-1 transition-transform duration-300 ease-out-quart hover:-translate-y-px">
            Download for Mac (beta)
          </a>
