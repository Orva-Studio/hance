  <script is:inline>
    // Install pill: click to copy
    function initInstallPill() {
      const btn = document.getElementById('install-copy');
      if (!btn) return;
      const labelEl = btn.querySelector('[data-label]');
      const original = labelEl ? labelEl.textContent : 'copy';
      btn.addEventListener('click', async () => {
        const txt = btn.getAttribute('data-copy') || '';
        try {
          await navigator.clipboard.writeText(txt);
          if (labelEl) {
            labelEl.textContent = 'copied ✓';
            btn.classList.add('ring-1', 'ring-accent');
            setTimeout(() => {
              labelEl.textContent = original;
              btn.classList.remove('ring-1', 'ring-accent');
            }, 1500);
          }
        } catch (e) {
          if (labelEl) labelEl.textContent = 'press ⌘C';
        }
      });
    }

    // Reel: custom play/pause + scrub controls
    function initReel() {
      const video = document.getElementById('reel-video');
      const toggle = document.getElementById('reel-toggle');
      const track = document.getElementById('reel-track');
      const progress = document.getElementById('reel-progress');
      const thumb = document.getElementById('reel-thumb');
      const timeEl = document.getElementById('reel-time');
      if (!video || !toggle || !track) return;

      const iconPlay = toggle.querySelector('.reel-icon-play');
      const iconPause = toggle.querySelector('.reel-icon-pause');
      const fmt = (s) => {
        if (!isFinite(s)) return '0:00';
        const m = Math.floor(s / 60);
        const r = Math.floor(s % 60);
        return m + ':' + String(r).padStart(2, '0');
      };
      const setPaused = (paused) => {
        iconPlay.classList.toggle('hidden', !paused);
        iconPause.classList.toggle('hidden', paused);
        toggle.setAttribute('aria-label', paused ? 'Play' : 'Pause');
      };
      const togglePlay = () => {
        if (video.paused) video.play(); else video.pause();
      };
      // Sync the icon with reality in case autoplay was blocked.
      setPaused(video.paused);
      toggle.addEventListener('click', togglePlay);
      video.addEventListener('click', togglePlay);
      video.addEventListener('play', () => setPaused(false));
      video.addEventListener('pause', () => setPaused(true));
      video.addEventListener('timeupdate', () => {
        const pct = video.duration ? (video.currentTime / video.duration) * 100 : 0;
        progress.style.width = pct + '%';
        thumb.style.left = pct + '%';
        timeEl.textContent = fmt(video.currentTime);
      });

      const seekTo = (clientX) => {
        const rect = track.getBoundingClientRect();
        const pct = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
        if (video.duration) video.currentTime = pct * video.duration;
      };
      let scrubbing = false;
      track.addEventListener('pointerdown', (e) => {
        scrubbing = true; track.setPointerCapture(e.pointerId); seekTo(e.clientX);
      });
      track.addEventListener('pointermove', (e) => { if (scrubbing) seekTo(e.clientX); });
      track.addEventListener('pointerup', () => { scrubbing = false; });
      track.addEventListener('pointercancel', () => { scrubbing = false; });
    }

    // Install command blocks: click to copy
    function initCommandBlocks() {
      const buttons = document.querySelectorAll('.cb-copy');
      buttons.forEach((btn) => {
        const labelEl = btn.querySelector('[data-label]');
        const original = labelEl ? labelEl.textContent : 'Copy';
        btn.addEventListener('click', async () => {
          const txt = btn.getAttribute('data-copy') || '';
          try {
            await navigator.clipboard.writeText(txt);
            if (labelEl) labelEl.textContent = 'Copied ✓';
            btn.classList.add('is-copied');
            setTimeout(() => {
              if (labelEl) labelEl.textContent = original;
              btn.classList.remove('is-copied');
            }, 1500);
          } catch (e) {
            if (labelEl) labelEl.textContent = 'Press ⌘C';
          }
        });
      });
    }

    // Before/after slider
    // Wire each before/after slider independently. Each .ba element owns its
    // own --pos, inherited by its .ba-after clip and .ba-handle.
    function initBeforeAfter() {
      document.querySelectorAll('.ba').forEach((wrap) => {
        const range = wrap.querySelector('.ba-range');
        if (!range) return;
        const setPos = (pct) => {
          const v = Math.max(0, Math.min(100, pct));
          wrap.style.setProperty('--pos', v + '%');
          range.value = String(v);
        };
        setPos(50);
        range.addEventListener('input', (e) => setPos(Number(e.target.value)));
        const onMove = (clientX) => {
          const rect = wrap.getBoundingClientRect();
          setPos(((clientX - rect.left) / rect.width) * 100);
        };
        let dragging = false;
        wrap.addEventListener('pointerdown', (e) => { dragging = true; onMove(e.clientX); });
        window.addEventListener('pointermove', (e) => { if (dragging) onMove(e.clientX); });
        window.addEventListener('pointerup', () => { dragging = false; });
      });
    }

    // Carousel: arrows + dots step between comparison slides. Drag is reserved
    // for the comparison slider, so slides change only via explicit controls.
    function initCompareCarousel() {
      const root = document.getElementById('ba-carousel');
      const track = document.getElementById('ba-track');
      if (!root || !track) return;
      const slides = Array.from(track.children);
      const dots = Array.from(root.querySelectorAll('.ba-dot'));
      const caption = document.getElementById('ba-caption');
      const prev = document.getElementById('ba-prev');
      const next = document.getElementById('ba-next');
      let index = 0;

      const render = () => {
        track.style.transform = `translateX(-${index * 100}%)`;
        slides.forEach((slide, i) => {
          const active = i === index;
          slide.toggleAttribute('inert', !active);
          slide.setAttribute('aria-hidden', String(!active));
        });
        dots.forEach((dot, i) => {
          const active = i === index;
          dot.classList.toggle('bg-accent', active);
          dot.classList.toggle('bg-surface-3', !active);
          dot.setAttribute('aria-selected', String(active));
        });
        const ba = slides[index].querySelector('.ba');
        const preset = ba?.dataset.preset;
        if (caption && preset) caption.textContent = preset;
        const tunedEl = document.getElementById('ba-tuned');
        if (tunedEl) tunedEl.textContent = ba?.dataset.tuned === 'true' ? ' (tuned)' : '';
      };

      const goTo = (i) => { index = (i + slides.length) % slides.length; render(); };
      prev?.addEventListener('click', () => goTo(index - 1));
      next?.addEventListener('click', () => goTo(index + 1));
      dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
      root.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') { e.preventDefault(); goTo(index - 1); }
        else if (e.key === 'ArrowRight') { e.preventDefault(); goTo(index + 1); }
      });
      render();
    }

    initInstallPill();
    initReel();
    initCommandBlocks();
    initBeforeAfter();
    initCompareCarousel();
  </script>
</Base>

