{
  "hance_version": "0.3.1",
  "name": "Fujicolor 200",
  "description": "Fujicolor C200 — budget Fuji stock with cool greens and clean daylight rendering",
  "keywords": ["fujicolor", "fuji", "c200", "consumer", "cool", "green"],
