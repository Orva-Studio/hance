    "subtractive-sat": 1.05,
    "richness": 1.05,
    "bleach-bypass": 0,
    "halation-amount": 0.2,
    "halation-radius": 5,
    "halation-highlights-only": true,
    "aberration": 0.2,
    "bloom-amount": 0.18,
    "bloom-radius": 8,
    "grain-iso": 300,
    "grain-size": 0.6,
    "grain-softness": 0.14,
    "grain-saturation": 0.28,
    "vignette-amount": 0.18,
    "vignette-size": 0.3,
    "split-tone-amount": 0.18,
    "split-tone-shadow-hue": 125,
    "split-tone-highlight-hue": 125,
    "split-tone-pivot": 0.33,
    "camera-shake-amount": 0.1,
    "camera-shake-rate": 0.45
  }
